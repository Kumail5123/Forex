# Server
PORT=4000
JWT_SECRET=replace_this_with_a_long_random_secret_in_production

# Postgres connection string. On Render, this is set automatically when
# you deploy via render.yaml. For local dev, point at your own Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/forex_app

# Broker integration (fill in once you're approved as an IB / have API access)
# AvaTrade / OANDA practice API credentials go here — never commit real keys.
BROKER_CLIENT_ID=your_broker_partner_client_id
BROKER_CLIENT_SECRET=your_broker_partner_client_secret
BROKER_REDIRECT_URI=forexapp://broker-callback
BROKER_API_BASE_URL=https://api-fxpractice.oanda.com

# AvaPartner referral tag (from avapartner.com > Marketing Tools > Direct Links)
# This is what actually works today — a tracked referral link, not an OAuth flow.
AVA_PARTNER_TAG=your_avapartner_tag

# Random string YOU choose — put it in the Postback Pixel URL as ?secret=...
# so only real AvaPartner postbacks are accepted, not random requests.
AVA_POSTBACK_SECRET=choose_a_long_random_string

# IB / partner tracking code the broker gave you, appended to referral links
IB_PARTNER_ID=your_ib_partner_id
